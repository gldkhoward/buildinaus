# Neon Postgres connection string (pooled). Used by @buildinaus/database (Drizzle)
# and by drizzle-kit migrations. Auto-provisioned by the Vercel + Neon integration.
DATABASE_URL=

# Neon Auth — both auto-provisioned by the Vercel + Neon Auth integration.
# The browser never touches Neon Auth directly; it hits same-origin
# /api/auth/* and the Next.js route handler proxies to NEON_AUTH_BASE_URL.
NEON_AUTH_BASE_URL=
NEXT_AUTH_COOKIE_SECRET=
