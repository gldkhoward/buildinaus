{
  "name": "@buildinaus/database",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "lint": "echo \"(no lint configured)\"",
    "type-check": "tsc --noEmit",
    "db:generate": "dotenv -e ../../apps/web/.env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../apps/web/.env.local -- drizzle-kit migrate",
    "db:push": "dotenv -e ../../apps/web/.env.local -- drizzle-kit push",
    "db:seed": "dotenv -e ../../apps/web/.env.local -- tsx src/seed.ts",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "drizzle-orm": "^0.45.0"
  },
  "devDependencies": {
    "@buildinaus/config": "workspace:*",
    "@types/node": "^22",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.0",
    "tsx": "^4.19.0",
    "typescript": "5.7.3"
  }
}
