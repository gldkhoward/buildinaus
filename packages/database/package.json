{
  "name": "@buildinaus/database",
  "version": "0.1.0",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "lint": "echo \"(no lint configured)\"",
    "type-check": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/seed.ts",
    "clean": "rm -rf .turbo dist *.tsbuildinfo"
  },
  "dependencies": {
    "@buildinaus/types": "workspace:*",
    "drizzle-orm": "^0.36.0",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@buildinaus/config": "workspace:*",
    "@types/node": "^22",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.19.0",
    "typescript": "5.7.3"
  }
}
